# If you come from bash you might have to change your $PATH.
# export PATH=$HOME/bin:/usr/local/bin:$PATH

# Path to your oh-my-zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Set name of the theme to load --- if set to "random", it will
# load a random theme each time oh-my-zsh is loaded, in which case,
# to know which specific one was loaded, run: echo $RANDOM_THEME
# See https://github.com/ohmyzsh/ohmyzsh/wiki/Themes
ZSH_THEME="agnoster" # set by `omz`

# Set list of themes to pick from when loading at random
# Setting this variable when ZSH_THEME=random will cause zsh to load
# a theme from this variable instead of looking in $ZSH/themes/
# If set to an empty array, this variable will have no effect.
# ZSH_THEME_RANDOM_CANDIDATES=( "robbyrussell" "agnoster" )

# Uncomment the following line to use case-sensitive completion.
# CASE_SENSITIVE="true"

# Uncomment the following line to use hyphen-insensitive completion.
# Case-sensitive completion must be off. _ and - will be interchangeable.
# HYPHEN_INSENSITIVE="true"

# Uncomment one of the following lines to change the auto-update behavior
# zstyle ':omz:update' mode disabled  # disable automatic updates
# zstyle ':omz:update' mode auto      # update automatically without asking
# zstyle ':omz:update' mode reminder  # just remind me to update when it's time

# Uncomment the following line to change how often to auto-update (in days).
# zstyle ':omz:update' frequency 13

# Uncomment the following line if pasting URLs and other text is messed up.
# DISABLE_MAGIC_FUNCTIONS="true"

# Uncomment the following line to disable colors in ls.
# DISABLE_LS_COLORS="true"

# Uncomment the following line to disable auto-setting terminal title.
# DISABLE_AUTO_TITLE="true"

# Uncomment the following line to enable command auto-correction.
# ENABLE_CORRECTION="true"

# Uncomment the following line to display red dots whilst waiting for completion.
# You can also set it to another string to have that shown instead of the default red dots.
# e.g. COMPLETION_WAITING_DOTS="%F{yellow}waiting...%f"
# Caution: this setting can cause issues with multiline prompts in zsh < 5.7.1 (see #5765)
# COMPLETION_WAITING_DOTS="true"

# Uncomment the following line if you want to disable marking untracked files
# under VCS as dirty. This makes repository status check for large repositories
# much, much faster.
# DISABLE_UNTRACKED_FILES_DIRTY="true"

# Uncomment the following line if you want to change the command execution time
# stamp shown in the history command output.
# You can set one of the optional three formats:
# "mm/dd/yyyy"|"dd.mm.yyyy"|"yyyy-mm-dd"
# or set a custom format using the strftime function format specifications,
# see 'man strftime' for details.
# HIST_STAMPS="mm/dd/yyyy"

# Would you like to use another custom folder than $ZSH/custom?
# ZSH_CUSTOM=/path/to/new-custom-folder

# Which plugins would you like to load?
# Standard plugins can be found in $ZSH/plugins/
# Custom plugins may be added to $ZSH_CUSTOM/plugins/
# Example format: plugins=(rails git textmate ruby lighthouse)
# Add wisely, as too many plugins slow down shell startup.
# plugins=(git, docker, virtualenv, kubectl, history, tmux, gh, azure)
plugins=(git kubectl docker virtualenv gh azure opentofu dotnet fzf)

source $ZSH/oh-my-zsh.sh

# User configuration

# export MANPATH="/usr/local/man:$MANPATH"

# You may need to manually set your language environment
# export LANG=en_US.UTF-8

# Preferred editor for local and remote sessions
# if [[ -n $SSH_CONNECTION ]]; then
#   export EDITOR='vim'
# else
#   export EDITOR='mvim'
# fi

# Compilation flags
# export ARCHFLAGS="-arch x86_64"

# Set personal aliases, overriding those provided by oh-my-zsh libs,
# plugins, and themes. Aliases can be placed here, though oh-my-zsh
# users are encouraged to define aliases within the ZSH_CUSTOM folder.
# For a full list of active aliases, run `alias`.
#
# Example aliases
# alias zshconfig="mate ~/.zshrc"
# alias ohmyzsh="mate ~/.oh-my-zsh"

# Aliases
if type nvim &> /dev/null; then
	alias vim=nvim
fi

if type glow &> /dev/null; then
	alias glow="glow -p"
fi

if type eza &> /dev/null; then
  alias ls="eza --icons=always"
fi

prompt_context(){
  # empty
}

jwtd() {
    if [[ -x $(command -v jq) ]]; then
         jq -R 'split(".") | .[0],.[1] | @base64d | fromjson' <<< "${1}"
         echo "Signature: $(echo "${1}" | awk -F'.' '{print $3}')"
    fi
}

[[ -f "$HOME/.docker/init-zsh.sh" ]] && source $HOME/.docker/init-zsh.sh || true # Added by Docker Desktop
[[ $commands[kubectl] ]] && source <(kubectl completion zsh)

# OS-specific plugin directory
case "$(uname)" in
  Darwin) ZSH_PLUGIN_DIR="/opt/homebrew/share" ;;
  Linux)  ZSH_PLUGIN_DIR="/usr/share" ;;
esac

# On macOS, require tap trust for Homebrew plugins
case "$(uname)" in
  Darwin) HOMEBREW_REQUIRE_TAP_TRUST=1 ;;
esac

# External plugins
[[ -f "$ZSH_PLUGIN_DIR/zsh-autosuggestions/zsh-autosuggestions.zsh" ]] && \
  source "$ZSH_PLUGIN_DIR/zsh-autosuggestions/zsh-autosuggestions.zsh"
[[ -f "$ZSH_PLUGIN_DIR/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]] && \
  source "$ZSH_PLUGIN_DIR/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"

# If on macos, then and /opt/homebrew/opt/hunch/share/hunch/hunch.zsh exists and source /opt/homebrew/opt/hunch/share/hunch/hunch.zsh 
[[  $(uname) == "Darwin" && -f "/opt/homebrew/opt/hunch/share/hunch/hunch.zsh" ]] && \
  source "/opt/homebrew/opt/hunch/share/hunch/hunch.zsh"

# NVM
export NVM_DIR="$HOME/.nvm"
case "$(uname)" in
  Darwin) _NVM_HOME="/opt/homebrew/opt/nvm" ;;
  Linux)  _NVM_HOME="$NVM_DIR" ;;
esac
[ -s "$_NVM_HOME/nvm.sh" ] && \. "$_NVM_HOME/nvm.sh"
[ -s "$_NVM_HOME/etc/bash_completion.d/nvm" ] && \. "$_NVM_HOME/etc/bash_completion.d/nvm"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
unset _NVM_HOME
#
# Local bin
case ":$PATH:" in *":$HOME/.local/bin:"*) ;; *) export PATH="$HOME/.local/bin:$PATH" ;; esac

# Add $HOME/.cargo/bin to PATH if it exists
if [[ -d "$HOME/.cargo/bin" ]]; then
    export PATH="$HOME/.cargo/bin:$PATH"
fi

# Tools
if type vce &> /dev/null; then
    eval "$(vce init zsh)"
fi
if type zoxide &> /dev/null; then
    eval "$(zoxide init zsh)"
    alias cd="z"
fi
if type bat &> /dev/null; then
    alias cat="bat"
fi
if type fzf &> /dev/null; then
    source <(fzf --zsh)
fi
if type sara &> /dev/null; then
    source <(COMPLETE=zsh sara)
fi

# --- AI commit-message suggestion (Copilot backend) -----------------------
# Type `git commit` then press TAB to fill `git commit -m "…"` generated from
# your STAGED diff. Review it, edit if needed, then press Enter yourself.
# It never commits for you. Falls back to normal TAB completion (incl. fzf)
# everywhere else, and when nothing is staged.
_ai_commit_suggest() {
  emulate -L zsh
  local diff
  diff=$(git diff --cached --no-color 2>/dev/null)
  if [[ -z $diff ]]; then
    zle -M "ai-commit: nothing staged (git add first)"
    return 1
  fi

  zle -R "ai-commit: generating…"

  local prompt msg
  prompt='Generate a single-line git commit message for the staged git diff below. Use Conventional Commits style (e.g. "feat: …", "fix: …"). Output ONLY the message text — no quotes, no code fences, no explanation, no trailing period, max 72 chars. Diff:
'"$diff"
  # --available-tools= (empty whitelist) means NO tools are available to the
  # model, so it cannot run shell commands or edit files; --disable-builtin-mcps
  # drops the GitHub MCP server. Pure text generation only.
  # COPILOT_HOME points at a throwaway dir so this call's session does NOT land
  # in ~/.copilot's resume list (auth lives elsewhere, so this stays working).
  local cop_home
  cop_home=$(mktemp -d)
  msg=$(COPILOT_HOME="$cop_home" copilot -p "$prompt" --silent --no-color \
        --available-tools= --disable-builtin-mcps 2>/dev/null)
  rm -rf "$cop_home"
  msg=${msg%%$'\n'*}                       # first line only
  msg="${msg#"${msg%%[![:space:]]*}"}"     # trim leading whitespace
  msg="${msg%"${msg##*[![:space:]]}"}"     # trim trailing whitespace
  msg=${(Q)msg}                            # strip any wrapping quotes

  if [[ -z $msg ]]; then
    zle -M "ai-commit: no suggestion returned"
    return 1
  fi

  BUFFER="git commit -m \"${msg}\""
  (( CURSOR = ${#BUFFER} - 1 ))            # park cursor before the closing quote
  zle redisplay
}
zle -N _ai_commit_suggest

# Context-aware TAB: generate on `git commit[ …]`, otherwise normal completion.
_ai_commit_tab() {
  if [[ $BUFFER == "git commit"(|" "*) ]]; then
    _ai_commit_suggest
  elif (( ${+widgets[fzf-completion]} )); then
    zle fzf-completion          # preserve fzf's TAB completion
  else
    zle expand-or-complete      # default TAB completion
  fi
}
zle -N _ai_commit_tab
bindkey '^I' _ai_commit_tab
